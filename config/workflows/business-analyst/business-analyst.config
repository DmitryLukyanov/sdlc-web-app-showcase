{
  "name": "business_analyst",
  "params": {
    "runner": "pipeline",
    "onFailure": {
      "githubIssueComment": "Business Analyst pipeline failed — manual review required."
    },
    "steps": [
      {
        "runner": "llm_evaluate",
        "enabled": true
      },
      {
        "runner": "update_issue",
        "enabled": true
      },
      {
        "runner": "assign_copilot",
        "enabled": true
      }
    ]
  }
}
