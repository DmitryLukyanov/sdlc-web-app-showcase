{
  "rules": [
    {
      "description": "Priority 1 tickets first",
      "jql": "project = SDLCSPAC AND labels = priority1 ORDER BY updated ASC",
      "configFile": "config/workflows/ai-teammate/ai-teammate.config",
      "workflowFile": "ai-teammate.yml",
      "workflowRef": "master",
      "limit": 10,
      "skipIfLabel": "sm_triggered",
      "addLabel": "sm_triggered",
      "stopIfDispatched": true
    },
    {
      "description": "Remaining tickets (runs only if no priority1 tickets were dispatched)",
      "jql": "project = SDLCSPAC ORDER BY updated ASC",
      "configFile": "config/workflows/ai-teammate/ai-teammate.config",
      "workflowFile": "ai-teammate.yml",
      "workflowRef": "master",
      "limit": 10,
      "skipIfLabel": "sm_triggered",
      "addLabel": "sm_triggered"
    }
  ]
}
