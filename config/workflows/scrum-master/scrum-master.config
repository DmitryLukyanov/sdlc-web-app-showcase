{
  "rules": [
    {
      "description": "To Do queue → ticket processor (edit jql for your project)",
      "jql": "project = SDLCSPAC ORDER BY updated ASC",
      "configFile": "config/workflows/ai-teammate/ai-teammate.config",
      "workflowFile": "ai-teammate.yml",
      "workflowRef": "master",
      "limit": 10,
      "skipIfLabel": "sm_triggered",
      "addLabel": "sm_triggered"
    }
  ]
}
